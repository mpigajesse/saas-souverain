# Nœud PME — variables d'environnement
# Copier ce fichier en .env et remplir TOUTES les valeurs
# NE JAMAIS COMMITTER .env dans git

# ── Rôle de ce nœud ───────────────────────────────────────────────────────
# VM1 (premier installé) : primary / active
# VM2 (second installé)  : standby / passive
NODE_ROLE=primary
NODE_MODE=active

# ── PostgreSQL ─────────────────────────────────────────────────────────────
PG_USER=metier
PG_PASSWORD=
PG_DB=metier

# Mot de passe de l'utilisateur de réplication (identique sur primaire ET standby)
REPLICATION_PASSWORD=

# Sous-réseau autorisé à se connecter à PostgreSQL (réplication + pgAdmin)
# Exemple : 192.168.1.0/24 — laisser vide = 0.0.0.0/0 (protégé par mot de passe)
PG_REPLICATION_SUBNET=

# IP du nœud primaire (renseigné UNIQUEMENT sur le standby)
PRIMARY_IP=

# ── Réseau / Relais ────────────────────────────────────────────────────────
# Adresse IP:PORT de CE nœud, telle qu'elle est visible depuis les autres machines
NODE_ADDR=

# URL du relais zero-knowledge (ens34 du serveur relais éditeur)
RELAY_URL=

# ── Portail éditeur SaaS ───────────────────────────────────────────────────
# URL du portail Django éditeur
SAAS_URL=
# Token de licence de cette PME (copié depuis le portail éditeur → Tenants)
REGISTRATION_TOKEN=

# ── pgAdmin ────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@pme.local
PGADMIN_PASSWORD=
