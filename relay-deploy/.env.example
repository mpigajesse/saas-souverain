# Relais EL BARAA CONSULT — variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS COMMITTER .env dans git

# Token d'authentification pour les endpoints /api/blobs/
# Laisser vide = accès libre (spike uniquement — activer en prod)
RELAY_AUTH_TOKEN=

# Interfaces réseau du serveur relais (affiché dans le portail éditeur)
# Format : iface:ip:role séparés par des virgules
# Renseigner avec les IPs réelles du serveur (voir : ip a)
# Exemple : ens33:<IP_WAN_EDITEUR>:editeur,ens34:<IP_LAN_RELAY>:interne
RELAY_NETWORKS=

# Port d'écoute (défaut 8080 — exposé sur 0.0.0.0)
# RELAY_PORT=8080
